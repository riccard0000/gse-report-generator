# ============================================================
# GSE Report Generator — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# NON committare mai il file .env nel repository!
# ============================================================

# ─── BRANCH: feature/azure-deploy ────────────────────────────────────────
# URL base del proxy Azure Function.
#
# Sviluppo locale (con Azure Functions Core Tools):
#   VITE_API_BASE_URL=http://localhost:7071/api/proxy
#
# Produzione Azure (Static Web Apps → Function App collegata):
#   VITE_API_BASE_URL=/api/proxy
#   (percorso relativo: SWA instrada /api/* → Function App automaticamente)
#
# Con APIM davanti (futuro):
#   VITE_API_BASE_URL=https://<apim-name>.azure-api.net/gse/proxy
#
VITE_API_BASE_URL=http://localhost:7071/api/proxy

# ─── NOTA: NESSUNA CHIAVE API NEL FRONTEND ───────────────────────────────
# La chiave OpenRouter NON va mai in questo file e NON va nel frontend.
# Va configurata come Application Setting nella Azure Function App:
#
#   az functionapp config appsettings set \
#     --name gse-proxy \
#     --resource-group rg-gse-report \
#     --settings OPENROUTER_API_KEY="sk-or-..."
#
# Oppure tramite il portale Azure:
#   Function App → Configuration → Application settings → + New application setting
#   Name: OPENROUTER_API_KEY  |  Value: sk-or-...
#
# Ottieni una chiave gratuita su: https://openrouter.ai/keys
# I modelli usati sono tutti :free (nessun addebito):
#   - nvidia/nemotron-3-super-120b-a12b:free  (estrazione KPI e narrativa)
#   - google/gemma-4-31b-it:free              (fallback automatico)
# ============================================================

# ─── BLOB STORAGE (usato dalla Azure Function, non dal frontend) ──────────
# La connection string del Blob Storage va come Application Setting
# nella Function App, NON in questo file:
#
#   az functionapp config appsettings set \
#     --name gse-proxy \
#     --resource-group rg-gse-report \
#     --settings AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;..."
#
# Storage account: gsereportstorage
# Container PDF:   gse-pdf-files
# ============================================================
