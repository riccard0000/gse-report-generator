# Copia questo file in .env e inserisci la tua chiave API OpenRouter
# Ottieni la chiave (gratuita) da: https://openrouter.ai/settings/keys
# Non serve carta di credito per i modelli free!
VITE_OPENROUTER_API_KEY=sk-or-v1-la-tua-chiave-qui

# NON committare mai il file .env nel repository!
# Il file .env è già nel .gitignore
