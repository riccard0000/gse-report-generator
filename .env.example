# Copia questo file in .env e inserisci il tuo GitHub Personal Access Token
# Crea un PAT su: https://github.com/settings/tokens
# Permessi richiesti: nessuno specifico (il token di default va bene per GitHub Models)
# Non serve carta di credito — GitHub Models è gratuito entro i rate limit!
VITE_GITHUB_TOKEN=ghp_il_tuo_token_qui

# NON committare mai il file .env nel repository!
# Il file .env è già nel .gitignore
