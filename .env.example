# ============================================================
# GSE Report Generator — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# NON committare mai il file .env nel repository!
# ============================================================

# URL del tuo Cloudflare Worker proxy (dopo il deploy).
# In sviluppo locale usa l'URL di wrangler dev (default: http://localhost:8787)
# In produzione usa l'URL del Worker: https://gse-proxy.TUONOME.workers.dev
VITE_PROXY_URL=http://localhost:8787

# NOTA: La chiave OpenRouter NON va qui e NON va in nessun file frontend.
# Va configurata come Secret nel Worker con:
#   cd worker && wrangler secret put OPENROUTER_API_KEY
