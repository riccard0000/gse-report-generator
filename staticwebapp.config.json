{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "*.{js,css,svg,png,ico,woff,woff2,ttf,json}"]
  },
  "mimeTypes": {
    ".js":   "application/javascript",
    ".mjs":  "application/javascript",
    ".jsx":  "application/javascript",
    ".ts":   "application/javascript",
    ".tsx":  "application/javascript",
    ".css":  "text/css",
    ".svg":  "image/svg+xml",
    ".json": "application/json",
    ".woff": "font/woff",
    ".woff2":"font/woff2"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-cache",
    "X-Content-Type-Options": "nosniff"
  }
}
